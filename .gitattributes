# 모든 파일: LF (Unix 스타일) 유지
* text=auto eol=lf

# 바이너리 파일
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.mov binary
*.mp4 binary

# 문서
*.md text eol=lf
*.mdx text eol=lf
*.txt text eol=lf

# 코드
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.html text eol=lf

# 설정 파일
.env* text eol=lf
.eslintignore text eol=lf
.gitignore text eol=lf
.prettierignore text eol=lf
tsconfig.json text eol=lf
next.config.js text eol=lf
tailwind.config.ts text eol=lf
postcss.config.js text eol=lf

# 셸 스크립트
*.sh text eol=lf
*.bash text eol=lf

# Windows 배치 파일 (CRLF 유지)
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf
