{
  "name": "pomochi-mvp1",
  "version": "0.2.0",
  "private": true,
  "engines": {
    "node": ">=18.17.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "cross-env NEXT_DIST_DIR=.next-build next build",
    "build:static": "cross-env NEXT_BUILD_STATIC=true next build",
    "test": "vitest run",
    "test:watch": "vitest",
    "cap:install": "npm install @capacitor/core @capacitor/cli @capacitor/ios @capacitor/android",
    "cap:init": "npx cap init",
    "cap:add:ios": "npx cap add ios",
    "cap:build": "npm run build:static && npx cap copy",
    "cap:open:ios": "npx cap open ios",
    "cap:sync": "npx cap sync",
    "cap:run:ios": "npx cap run ios"
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "overrides": {
    "postcss": "$postcss"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^5.1.2",
    "autoprefixer": "^10.4.20",
    "cross-env": "^10.1.0",
    "jsdom": "^25.0.1",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vitest": "^4.1.9"
  }
}
